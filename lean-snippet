#!/usr/bin/env bash
# lean-snippet — generate a self-contained highlighted Lean HTML snippet.
#
# Usage:
#   lean-snippet [file.lean] [options]
#   lean-snippet link="<live.lean-lang.org URL>" [options]   (or link=- to read stdin)
#
# Options:
#   -o, --output NAME   Base name for the output file (default: lean-code)
#   --multi-blocks      One box per top-level command (default: a single box)
#   --anchor NAME       Show only the region marked -- ANCHOR: NAME / -- ANCHOR_END: NAME
#   --label TEXT        Caption above the snippet (defaults to the anchor name)
#   --literate, -l      Open with Literate on: /-! … -/ blocks as prose (Markdown + \$LaTeX\$)
#   --infoview, -i      Open with the Infoview panel on — click a name/tactic for its info in a
#       [=both]         right-side panel; -i=both also turns hover on. (inspired by verso-slides)
#   --no-switcher       Emit a single fixed mode instead of the default "View" switcher
#
# The output has a live "View" dropdown (Hover / Infoview / Literate). Each mode flag turns ITS
# mode on; with NO mode flag, all start on. --anchor keeps the switcher (Literate disabled).
#   --no-output         Hide #eval / #check output (shown at the block bottom by default)
#   --no-enhance        Skip GitHub colors + Copy / Try-it buttons
#   --setup             First-time setup: build the renderer
#
# Pipeline (all Lean / SubVerso — no Python, no HTML scraping):
#   1. copy your file into the `Snippet` module
#   2. `lake build Snippet:highlighted`  → SubVerso highlights it to JSON
#   3. `render-snippet`                  → Verso renders the JSON to one HTML file
#
# Install (run once):
#   ln -s /path/to/snippets/lean-snippet ~/bin/lean-snippet
#   lean-snippet --setup

set -euo pipefail

# Resolve the real location of this script, following symlinks
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do SOURCE="$(readlink "$SOURCE")"; done
SNIPPETS_HOME="$(cd "$(dirname "$SOURCE")" && pwd)"
USER_CWD="$(pwd)"

# ── Parse arguments ───────────────────────────────────────────────────────────
SCRATCH=""
LINK=""
BASE="lean-code"
MULTI_BLOCKS=""
NO_ENHANCE=""
NO_OUTPUT=""
INFOVIEW=""
LITERATE=""
NO_SWITCHER=""
ANCHOR=""
LABEL=()
SETUP=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --setup)         SETUP=true; shift ;;
    -o|--output)     BASE="$2"; shift 2 ;;
    --multi-blocks)  MULTI_BLOCKS="--multi-blocks"; shift ;;
    --no-enhance)    NO_ENHANCE="--no-enhance"; shift ;;
    --no-output)     NO_OUTPUT="--no-output"; shift ;;
    --literate|-l)   LITERATE="--literate"; shift ;;
    --no-switcher)   NO_SWITCHER="--no-switcher"; shift ;;
    --infoview|-i)   INFOVIEW="--infoview"; shift ;;
    --infoview=*)    INFOVIEW="$1"; shift ;;
    -i=*)            INFOVIEW="--infoview=${1#*=}"; shift ;;
    --anchor)        ANCHOR="--anchor $2"; shift 2 ;;
    --label)         LABEL=(--label "$2"); shift 2 ;;
    link=*)          LINK="${1#link=}"; shift ;;
    --link)          LINK="$2"; shift 2 ;;
    --*)             echo "Unknown option: $1" >&2; exit 1 ;;
    *)               SCRATCH="$1"; shift ;;
  esac
done

# Run a build step quietly; print full output and abort only on failure.
build_step() {
  local out rc
  set +e
  out="$(lake build "$@" 2>&1)"; rc=$?
  set -e
  if [[ $rc -ne 0 ]]; then
    echo "$out"
    echo "Error: 'lake build $*' failed" >&2
    exit 1
  fi
  return 0
}

# ── Setup mode ────────────────────────────────────────────────────────────────
if $SETUP; then
  echo "lean-snippet: setting up in $SNIPPETS_HOME ..."
  cd "$SNIPPETS_HOME"
  build_step render-snippet
  echo "Setup complete. Run: lean-snippet your-file.lean"
  exit 0
fi

# ── Resolve input file ────────────────────────────────────────────────────────
# `link=<url>` (or `--link <url>`, or `link=-` for stdin) pulls the code from a
# live.lean-lang.org share link and uses that as the input.
if [[ -n "$LINK" ]]; then
  DECODED="${TMPDIR:-/tmp}/lean-snippet-link.lean"
  python3 "$SNIPPETS_HOME/decode-link.py" "$LINK" > "$DECODED" \
    || { echo "Error: could not decode link" >&2; exit 1; }
  SCRATCH="$DECODED"
fi
if [[ -z "$SCRATCH" ]]; then
  if [[ -f "$USER_CWD/scratch.lean" ]]; then
    SCRATCH="$USER_CWD/scratch.lean"
  else
    SCRATCH="$SNIPPETS_HOME/scratch.lean"
  fi
fi
[[ "$SCRATCH" != /* ]] && SCRATCH="$USER_CWD/$SCRATCH"
[[ -f "$SCRATCH" ]] || { echo "Error: file not found: $SCRATCH" >&2; exit 1; }

cd "$SNIPPETS_HOME"

# ── 1. Place the user's code as the `Snippet` module ──────────────────────────
cp "$SCRATCH" Snippet.lean

# ── 2. Build the renderer (cached) and highlight the module to JSON ───────────
echo "lean-snippet: building renderer ..."
build_step render-snippet

echo "lean-snippet: highlighting $SCRATCH ..."
build_step Snippet:highlighted
HL_JSON=".lake/build/highlighted/Snippet.json"
[[ -f "$HL_JSON" ]] || { echo "Error: highlight step produced no JSON" >&2; exit 1; }

# ── 3. Render the JSON to a single self-contained HTML file ───────────────────
echo "lean-snippet: rendering ..."
OUT="${BASE}.html"
.lake/build/bin/render-snippet "$HL_JSON" "$SNIPPETS_HOME/$OUT" $NO_SWITCHER $MULTI_BLOCKS $NO_ENHANCE $NO_OUTPUT $LITERATE $INFOVIEW $ANCHOR "${LABEL[@]}"
[[ "$SNIPPETS_HOME/$OUT" != "$USER_CWD/$OUT" ]] && cp "$SNIPPETS_HOME/$OUT" "$USER_CWD/$OUT"
echo "  → $USER_CWD/$OUT"
echo "lean-snippet: done!"
