#!/usr/bin/env bash
# lean-snippet — generate highlighted Lean HTML from any directory.
#
# Usage:
#   lean-snippet [file.lean] [options]
#
# Options:
#   --index N      Extract only block N
#   --split        One file per #show region: demo-0.html, demo-1.html, ...
#   --no-enhance   Skip GitHub colors / copy / Try-it buttons
#   --out NAME     Output filename (default: demo.html)
#   --setup        First-time setup: build the Verso project
#
# Install (run once):
#   ln -s /path/to/snippets/lean-snippet ~/bin/lean-snippet
#   lean-snippet --setup
#
# Then from any directory:
#   lean-snippet scratch.lean
#   lean-snippet proof.lean --split

set -euo pipefail

# Resolve the real location of this script even through symlinks
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do SOURCE="$(readlink "$SOURCE")"; done
SNIPPETS_HOME="$(cd "$(dirname "$SOURCE")" && pwd)"

USER_CWD="$(pwd)"

# ── Parse arguments ──────────────────────────────────────────────────────────
SCRATCH=""
EXTRA_ARGS=()
OUT="demo.html"
SPLIT=false
SETUP=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --setup)      SETUP=true; shift ;;
    --split)      SPLIT=true; EXTRA_ARGS+=("--split"); shift ;;
    --index)      EXTRA_ARGS+=("--index" "$2"); shift 2 ;;
    --no-enhance) EXTRA_ARGS+=("--no-enhance"); shift ;;
    --out)        OUT="$2"; shift 2 ;;
    --*)          echo "Unknown option: $1" >&2; exit 1 ;;
    *)            SCRATCH="$1"; shift ;;
  esac
done

# ── Setup mode ───────────────────────────────────────────────────────────────
if $SETUP; then
  echo "lean-snippet: setting up Verso project in $SNIPPETS_HOME ..."
  cd "$SNIPPETS_HOME"
  lake build generate-snippet
  echo "Setup complete. Run: lean-snippet your-file.lean"
  exit 0
fi

# ── Normal mode ──────────────────────────────────────────────────────────────
# Resolve scratch file path
if [[ -z "$SCRATCH" ]]; then
  # Look for scratch.lean in CWD, else use the one in SNIPPETS_HOME
  if [[ -f "$USER_CWD/scratch.lean" ]]; then
    SCRATCH="$USER_CWD/scratch.lean"
  else
    SCRATCH="$SNIPPETS_HOME/scratch.lean"
  fi
fi

# Make absolute
if [[ "$SCRATCH" != /* ]]; then
  SCRATCH="$USER_CWD/$SCRATCH"
fi

if [[ ! -f "$SCRATCH" ]]; then
  echo "Error: file not found: $SCRATCH" >&2
  exit 1
fi

# ── Build in the snippets project ────────────────────────────────────────────
cd "$SNIPPETS_HOME"

echo "lean-snippet: wrapping $SCRATCH ..."
python3 wrap_lean.py "$SCRATCH" > Snippet.lean

echo "lean-snippet: building ..."
lake build generate-snippet 2>&1 | grep -v "^info:\|^warning:\|^$" || true

echo "lean-snippet: generating site ..."
.lake/build/bin/generate-snippet 2>&1 | grep -v "^$" || true

# ── Extract and copy output to user's CWD ────────────────────────────────────
GENERATED_HTML="_site/index.html"
[[ -f "$GENERATED_HTML" ]] || { echo "Error: site generation failed" >&2; exit 1; }

SELECTED_ARG=""
if [[ -f "selected.json" ]]; then
  HAS_MARKERS=$(python3 -c "import json; print(json.load(open('selected.json')).get('has_markers', False))")
  [[ "$HAS_MARKERS" == "True" ]] && SELECTED_ARG="--selected selected.json"
fi

echo "lean-snippet: extracting ..."

if $SPLIT; then
  # Collect which indices to split on
  if [[ -n "$SELECTED_ARG" ]]; then
    INDICES=$(python3 -c "import json; print(*json.load(open('selected.json'))['selected'])")
  else
    INDICES=$(python3 extract_lean.py "$GENERATED_HTML" --list 2>/dev/null \
              | grep -oE '\[[0-9]+\]' | tr -d '[]' | tr '\n' ' ')
  fi
  for i in $INDICES; do
    OUTFILE="${OUT%.html}-${i}.html"
    python3 extract_lean.py "$GENERATED_HTML" --index "$i" \
        --out "$SNIPPETS_HOME/$OUTFILE" "${EXTRA_ARGS[@]}" || true
    cp "$SNIPPETS_HOME/$OUTFILE" "$USER_CWD/$OUTFILE"
    echo "  → $USER_CWD/$OUTFILE"
  done
else
  python3 extract_lean.py "$GENERATED_HTML" \
      --out "$SNIPPETS_HOME/$OUT" $SELECTED_ARG "${EXTRA_ARGS[@]}"
  cp "$SNIPPETS_HOME/$OUT" "$USER_CWD/$OUT"
  echo "  → $USER_CWD/$OUT"
fi

echo "lean-snippet: done!"
